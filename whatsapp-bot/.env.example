# Copy to .env (never commit real keys)

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: use this user when no profiles.whatsapp_phone match (local testing)
# DEV_FARMER_USER_ID=uuid-from-auth-users

# Use installed Chrome instead of bundled Chromium (recommended on Windows)
PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Google AI Studio — natural follow-ups after the farm summary
MURIMI_GEMINI_API_KEY=
# MURIMI_GEMINI_MODEL=gemini-flash-latest
